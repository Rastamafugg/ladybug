<?xml version="1.0"?>
<!DOCTYPE target SYSTEM "gdb-target.dtd">
<target version="1.0">
  <architecture>m68k</architecture>
  <feature name="org.gnu.gdb.m6809.core">
    <reg name="cc" bitsize="8" regnum="0"/>
    <reg name="a"  bitsize="8" regnum="1"/>
    <reg name="b"  bitsize="8" regnum="2"/>
    <reg name="dp" bitsize="8" regnum="3"/>
    <reg name="x"  bitsize="16" regnum="4"/>
    <reg name="y"  bitsize="16" regnum="5"/>
    <reg name="u"  bitsize="16" regnum="6"/>
    <reg name="s"  bitsize="16" regnum="7" type="data_ptr"/>
    <reg name="pc" bitsize="16" regnum="8" type="code_ptr"/>
  </feature>
</target>
