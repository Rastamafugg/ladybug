                      (c/tester/tester.s):00147                 include "modes.inc"
                      (        modes.inc):00001         ;==============================================================================
                      (        modes.inc):00002         ; modes.inc — Mode table for the tester ROM.
                      (        modes.inc):00003         ; Each record: 5 bytes (vmode, vres, border, voff1, voff0).
                      (        modes.inc):00004         ; v0 has one mode; WS-D expands the matrix.
                      (        modes.inc):00005         ; Both the table label and TM_* offsets are emitted to build/tester.map.
                      (        modes.inc):00006         ;==============================================================================
                      (        modes.inc):00007         
     0000             (        modes.inc):00008         TM_VMODE   equ 0
     0001             (        modes.inc):00009         TM_VRES    equ 1
     0002             (        modes.inc):00010         TM_BORDER  equ 2
     0003             (        modes.inc):00011         TM_VOFF1   equ 3
     0004             (        modes.inc):00012         TM_VOFF0   equ 4
     0005             (        modes.inc):00013         TM_LEN     equ 5
                      (        modes.inc):00014         
C189                  (        modes.inc):00015         tester_mode_table
                      (        modes.inc):00016                 ; Mode 0: 320x192x16 (Format C). BP=1, VRES=00 HRES=111 CRES=10.
                      (        modes.inc):00017                 ; FB at virt $2000 → phys $072000 (MMU off, top-64K window).
C189 80               (        modes.inc):00018                 fcb     $80     ; vmode
C18A 1E               (        modes.inc):00019                 fcb     $1E     ; vres (final, unblanked)
C18B 28               (        modes.inc):00020                 fcb     $28     ; border (bright pink)
C18C E4               (        modes.inc):00021                 fcb     $E4     ; voff1
C18D 00               (        modes.inc):00022                 fcb     $00     ; voff0
                      (        modes.inc):00023         
     0001             (        modes.inc):00024         TESTER_MODE_COUNT equ (*-tester_mode_table)/TM_LEN
