                      (c/tester/tester.s):00001         ;==============================================================================
                      (c/tester/tester.s):00002         ; tester.s — Emulator-monitor tester ROM, top-level.
                      (c/tester/tester.s):00003         ;
                      (c/tester/tester.s):00004         ; Milestone 1 (this file's current state): boot path, palette + mode setup
                      (c/tester/tester.s):00005         ; driven by tester_mode_table, draws the bars pattern once, spins. No IRQ,
                      (c/tester/tester.s):00006         ; no keyboard yet — those land in milestone 2.
                      (c/tester/tester.s):00007         ;
                      (c/tester/tester.s):00008         ; See wiki/implementation/emulator-monitor-tester.md for the architect spec.
                      (c/tester/tester.s):00009         ; Source-of-truth for boot recipe: src/diag_minimal.s (the working 16-stripe
                      (c/tester/tester.s):00010         ; minimal cart from 2026-05-16).
                      (c/tester/tester.s):00011         ;
                      (c/tester/tester.s):00012         ; Operating envelope:
                      (c/tester/tester.s):00013         ;   - No MMU ($FF90 bit 6 = 0). Virtual = physical $07xxxx.
                      (c/tester/tester.s):00014         ;   - Cart executes from cart ROM at $C000-$FDFF — no self-copy (works around
                      (c/tester/tester.s):00015         ;     XRoar's cart-shadow gotcha; see lessons-learned.md).
                      (c/tester/tester.s):00016         ;   - RW state at virtual $0000-$1FFE, FB at $2000, stack just below FB.
                      (c/tester/tester.s):00017         ;   - IRQ jump table at $FE00-$FEFF (RAM-backed via Init0 bit 3 = 1).
                      (c/tester/tester.s):00018         ;==============================================================================
                      (c/tester/tester.s):00019         
                      (c/tester/tester.s):00020                 pragma  nodollarlocal,6809
                      (c/tester/tester.s):00021         
                      (c/tester/tester.s):00022         ; --- GIME register equates ---------------------------------------------------
     FF90             (c/tester/tester.s):00023         GIME_INIT0   equ $FF90
     FF98             (c/tester/tester.s):00024         GIME_VMODE   equ $FF98
     FF99             (c/tester/tester.s):00025         GIME_VRES    equ $FF99
     FF9A             (c/tester/tester.s):00026         GIME_BORDER  equ $FF9A
     FF9D             (c/tester/tester.s):00027         GIME_VOFF1   equ $FF9D
     FF9E             (c/tester/tester.s):00028         GIME_VOFF0   equ $FF9E
     FFB0             (c/tester/tester.s):00029         PAL_BASE     equ $FFB0
                      (c/tester/tester.s):00030         
     2000             (c/tester/tester.s):00031         FB_VIRT      equ $2000
     001F             (c/tester/tester.s):00032         BLANK_VRES   equ $1F           ; VRES with CRES=11 → forced blank during mode change
                      (c/tester/tester.s):00033         
     FEF7             (c/tester/tester.s):00034         IRQ_VEC      equ $FEF7         ; secondary IRQ JMP slot (Init0 b3 makes this RAM-backed)
     FF92             (c/tester/tester.s):00035         GIME_IRQEN   equ $FF92         ; ACVC IRQ enable register
     0008             (c/tester/tester.s):00036         VBORD_IRQ    equ $08           ; $FF92 b3 = Vbord (60 Hz)
     0028             (c/tester/tester.s):00037         INIT0_RUN    equ $28           ; b5=1 ACVC-IRQ enable, b3=1 force $FExx
                      (c/tester/tester.s):00038         
     FF01             (c/tester/tester.s):00039         PIA1_CRA     equ $FF01
     FF03             (c/tester/tester.s):00040         PIA1_CRB     equ $FF03
                      (c/tester/tester.s):00041         
                      (c/tester/tester.s):00042         ; --- DP slot declarations ($02xx) --------------------------------------------
                      (c/tester/tester.s):00043                 include "dp.inc"
                      (           dp.inc):00001         ;==============================================================================
                      (           dp.inc):00002         ; dp.inc — Direct Page slot layout for the tester ROM.
                      (           dp.inc):00003         ; DP page = $02. All labels exported to build/tester.map so the web app
                      (           dp.inc):00004         ; (Option-2 ProgramStateStrategy) can read mode/pattern state by symbol.
                      (           dp.inc):00005         ;==============================================================================
                      (           dp.inc):00006         
                      (           dp.inc):00007                 org     $0200
0200                  (           dp.inc):00008         tester_mode_idx         rmb 1   ; current mode (index into tester_mode_table)
0201                  (           dp.inc):00009         tester_pattern_idx      rmb 1   ; current pattern (index into pattern_jump_table)
0202                  (           dp.inc):00010         tester_selection_dirty  rmb 1   ; ISR sets, mainloop clears + redraws
0203                  (           dp.inc):00011         tester_kbd_prev         rmb 8   ; per-column DRA snapshot for edge detection
020B                  (           dp.inc):00012         tester_frame_ctr        rmb 2   ; 60 Hz tick, debug
020D                  (           dp.inc):00013         ksc_scratch             rmb 1   ; kbd_scan_and_dispatch scratch
                      (c/tester/tester.s):00044         
                      (c/tester/tester.s):00045         ; --- ROM entry ---------------------------------------------------------------
                      (c/tester/tester.s):00046                 org     $C000
C000 444B             (c/tester/tester.s):00047                 fcc     "DK"            ; cart autostart magic; FIRQ entry at $C002
                      (c/tester/tester.s):00048         
C002                  (c/tester/tester.s):00049         entry
C002 1A50             (c/tester/tester.s):00050                 orcc    #$50            ; mask IRQ + FIRQ
C004 10CE1FFE         (c/tester/tester.s):00051                 lds     #$1FFE          ; stack just below FB
                      (c/tester/tester.s):00052         
                      (c/tester/tester.s):00053                 ; DP = $02 so dp.inc slots resolve short.
C008 8602             (c/tester/tester.s):00054                 lda     #$02
C00A 1F8B             (c/tester/tester.s):00055                 tfr     a,dp
     02               (c/tester/tester.s):00056                 setdp   $02
                      (c/tester/tester.s):00057         
                      (c/tester/tester.s):00058                 ; Init0: CoCo3, MMU off, all ACVC IRQs off, force $FExx jumps.
C00C 8608             (c/tester/tester.s):00059                 lda     #%00001000
C00E B7FF90           (c/tester/tester.s):00060                 sta     GIME_INIT0
                      (c/tester/tester.s):00061         
                      (c/tester/tester.s):00062                 ; PIA1 init for keyboard scan. Cart-autorun under XRoar leaves PIA1
                      (c/tester/tester.s):00063                 ; in an unstable state for our purposes — explicit init avoids
                      (c/tester/tester.s):00064                 ; spurious DRA reads (observed: cols 0-3 read $00 with default state).
                      (c/tester/tester.s):00065                 ; CRA/CRB bit 2 = 0 selects DDR access; bit 2 = 1 selects data reg.
C011 7FFF01           (c/tester/tester.s):00066                 clr     PIA1_CRA           ; CRA: DDR access
C014 7FFF03           (c/tester/tester.s):00067                 clr     PIA1_CRB           ; CRB: DDR access
C017 7FFF00           (c/tester/tester.s):00068                 clr     $FF00              ; DDRA = 0 (rows are inputs)
C01A 86FF             (c/tester/tester.s):00069                 lda     #$FF
C01C B7FF02           (c/tester/tester.s):00070                 sta     $FF02              ; DDRB = $FF (columns are outputs)
C01F 8604             (c/tester/tester.s):00071                 lda     #$04               ; b2=1 data-reg access, all else neutral
C021 B7FF01           (c/tester/tester.s):00072                 sta     PIA1_CRA
C024 B7FF03           (c/tester/tester.s):00073                 sta     PIA1_CRB
                      (c/tester/tester.s):00074         
                      (c/tester/tester.s):00075                 ; Zero DP state.
C027 0F00             (c/tester/tester.s):00076                 clr     tester_mode_idx
C029 0F01             (c/tester/tester.s):00077                 clr     tester_pattern_idx
C02B 0F02             (c/tester/tester.s):00078                 clr     tester_selection_dirty
C02D 8E0203           (c/tester/tester.s):00079                 ldx     #tester_kbd_prev
C030 C60A             (c/tester/tester.s):00080                 ldb     #10             ; 8 prev + 2 frame_ctr
C032 6F80             (c/tester/tester.s):00081         clr_dp  clr     ,x+
C034 5A               (c/tester/tester.s):00082                 decb
C035 26FB             (c/tester/tester.s):00083                 bne     clr_dp
                      (c/tester/tester.s):00084         
                      (c/tester/tester.s):00085                 ; Load palette.
C037 308D0153         (c/tester/tester.s):00086                 leax    palette_table,pcr
C03B 108EFFB0         (c/tester/tester.s):00087                 ldy     #PAL_BASE
C03F C610             (c/tester/tester.s):00088                 ldb     #16
C041 A680             (c/tester/tester.s):00089         pal     lda     ,x+
C043 A7A0             (c/tester/tester.s):00090                 sta     ,y+
C045 5A               (c/tester/tester.s):00091                 decb
C046 26F9             (c/tester/tester.s):00092                 bne     pal
                      (c/tester/tester.s):00093         
                      (c/tester/tester.s):00094                 ; Apply mode 0 + pattern 0 (bars).
C048 BDC07E           (c/tester/tester.s):00095                 jsr     redraw_with_blank
                      (c/tester/tester.s):00096         
                      (c/tester/tester.s):00097                 ; Install Vbord ISR at $FEF7 (JMP vbord_isr).
C04B 867E             (c/tester/tester.s):00098                 lda     #$7E            ; JMP extended opcode
C04D B7FEF7           (c/tester/tester.s):00099                 sta     IRQ_VEC
C050 CCC070           (c/tester/tester.s):00100                 ldd     #vbord_isr
C053 FDFEF8           (c/tester/tester.s):00101                 std     IRQ_VEC+1
                      (c/tester/tester.s):00102         
                      (c/tester/tester.s):00103                 ; Enable Vbord interrupt in GIME, then enable IRQ delivery to CPU.
C056 8608             (c/tester/tester.s):00104                 lda     #VBORD_IRQ
C058 B7FF92           (c/tester/tester.s):00105                 sta     GIME_IRQEN
C05B B6FF92           (c/tester/tester.s):00106                 lda     GIME_IRQEN      ; read to clear any pending
C05E 8628             (c/tester/tester.s):00107                 lda     #INIT0_RUN
C060 B7FF90           (c/tester/tester.s):00108                 sta     GIME_INIT0
                      (c/tester/tester.s):00109         
                      (c/tester/tester.s):00110                 ; Unmask CPU IRQ.
C063 1CEF             (c/tester/tester.s):00111                 andcc   #$EF            ; clear I
                      (c/tester/tester.s):00112         
                      (c/tester/tester.s):00113                 ; --- Main loop: spin on selection_dirty; redraw when set.
C065                  (c/tester/tester.s):00114         mainloop
C065 9602             (c/tester/tester.s):00115                 lda     tester_selection_dirty
C067 27FC             (c/tester/tester.s):00116                 beq     mainloop
C069 0F02             (c/tester/tester.s):00117                 clr     tester_selection_dirty
C06B BDC07E           (c/tester/tester.s):00118                 jsr     redraw_with_blank
C06E 20F5             (c/tester/tester.s):00119                 bra     mainloop
                      (c/tester/tester.s):00120         
                      (c/tester/tester.s):00121         ;==============================================================================
                      (c/tester/tester.s):00122         ; vbord_isr — Vertical-border IRQ handler.
                      (c/tester/tester.s):00123         ;
                      (c/tester/tester.s):00124         ; CPU has pushed full register state; just ACK, bump tick, scan keyboard, RTI.
                      (c/tester/tester.s):00125         ; Target: <200 cycles per architect spec.
                      (c/tester/tester.s):00126         ;
                      (c/tester/tester.s):00127         ;  Inputs:  (IRQ entry — full register set on stack)
                      (c/tester/tester.s):00128         ;  Returns: (RTI restores everything)
                      (c/tester/tester.s):00129         ;  Side effects: reads $FF92 (ACK); bumps tester_frame_ctr; runs
                      (c/tester/tester.s):00130         ;                kbd_scan_and_dispatch which may set tester_selection_dirty.
                      (c/tester/tester.s):00131         ;==============================================================================
C070                  (c/tester/tester.s):00132         vbord_isr
C070 F6FF92           (c/tester/tester.s):00133                 ldb     GIME_IRQEN      ; ACK ACVC IRQ
C073 DC0B             (c/tester/tester.s):00134                 ldd     tester_frame_ctr
C075 C30001           (c/tester/tester.s):00135                 addd    #1
C078 DD0B             (c/tester/tester.s):00136                 std     tester_frame_ctr
C07A BDC0C7           (c/tester/tester.s):00137                 jsr     kbd_scan_and_dispatch
C07D 3B               (c/tester/tester.s):00138                 rti
                      (c/tester/tester.s):00139         
                      (c/tester/tester.s):00140         ; --- Renderer + dispatch ------------------------------------------------------
                      (c/tester/tester.s):00141                 include "render.s"
                      (         render.s):00001         ;==============================================================================
                      (         render.s):00002         ; render.s — pattern dispatch and the mode-change redraw sequence.
                      (         render.s):00003         ;==============================================================================
                      (         render.s):00004         
                      (         render.s):00005         ;------------------------------------------------------------------------------
                      (         render.s):00006         ; redraw_with_blank — apply current mode + pattern.
                      (         render.s):00007         ; Blanks via CRES=11, reprograms mode regs from tester_mode_table[idx], draws
                      (         render.s):00008         ; the current pattern, then unblanks by writing the mode's real VRES byte.
                      (         render.s):00009         ;
                      (         render.s):00010         ;  Inputs:
                      (         render.s):00011         ;       tester_mode_idx     - mode table index
                      (         render.s):00012         ;       tester_pattern_idx  - pattern jump table index
                      (         render.s):00013         ;  Returns: (none)
                      (         render.s):00014         ;  Side effects: writes $FF98/$FF99/$FF9A/$FF9D/$FF9E; rewrites FB.
                      (         render.s):00015         ;------------------------------------------------------------------------------
C07E                  (         render.s):00016         redraw_with_blank
C07E 861F             (         render.s):00017                 lda     #BLANK_VRES
C080 B7FF99           (         render.s):00018                 sta     GIME_VRES
                      (         render.s):00019         
C083 D600             (         render.s):00020                 ldb     tester_mode_idx
C085 8605             (         render.s):00021                 lda     #TM_LEN
C087 3D               (         render.s):00022                 mul                     ; D = idx * TM_LEN
C088 308D00FD         (         render.s):00023                 leax    tester_mode_table,pcr
C08C 308B             (         render.s):00024                 leax    d,x
                      (         render.s):00025         
C08E A6890000         (         render.s):00026                 lda     TM_VMODE,x
C092 B7FF98           (         render.s):00027                 sta     GIME_VMODE
C095 A6890002         (         render.s):00028                 lda     TM_BORDER,x
C099 B7FF9A           (         render.s):00029                 sta     GIME_BORDER
C09C A6890003         (         render.s):00030                 lda     TM_VOFF1,x
C0A0 B7FF9D           (         render.s):00031                 sta     GIME_VOFF1
C0A3 A6890004         (         render.s):00032                 lda     TM_VOFF0,x
C0A7 B7FF9E           (         render.s):00033                 sta     GIME_VOFF0
                      (         render.s):00034         
                      (         render.s):00035                 ; Stash final-VRES across the draw call; renderers clobber freely.
C0AA A6890001         (         render.s):00036                 lda     TM_VRES,x
C0AE 3402             (         render.s):00037                 pshs    a
C0B0 BDC0B9           (         render.s):00038                 jsr     draw_current_pattern
C0B3 3502             (         render.s):00039                 puls    a
C0B5 B7FF99           (         render.s):00040                 sta     GIME_VRES
C0B8 39               (         render.s):00041                 rts
                      (         render.s):00042         
                      (         render.s):00043         ;------------------------------------------------------------------------------
                      (         render.s):00044         ; draw_current_pattern — dispatch to renderer via pattern_jump_table.
                      (         render.s):00045         ;
                      (         render.s):00046         ;  Inputs:  tester_pattern_idx
                      (         render.s):00047         ;  Returns: (none)
                      (         render.s):00048         ;  Side effects: renderer-defined.
                      (         render.s):00049         ;------------------------------------------------------------------------------
C0B9                  (         render.s):00050         draw_current_pattern
C0B9 D601             (         render.s):00051                 ldb     tester_pattern_idx
C0BB 58               (         render.s):00052                 aslb                    ; byte → word offset
C0BC 308D0003         (         render.s):00053                 leax    pattern_jump_table,pcr
C0C0 AD95             (         render.s):00054                 jsr     [b,x]
C0C2 39               (         render.s):00055                 rts
                      (         render.s):00056         
C0C3                  (         render.s):00057         pattern_jump_table
C0C3 C140             (         render.s):00058                 fdb     pat_bars_draw
C0C5 C161             (         render.s):00059                 fdb     pat_check_draw
                      (c/tester/tester.s):00142                 include "input.s"
                      (          input.s):00001         ;==============================================================================
                      (          input.s):00002         ; input.s — Keyboard scan + edge-detect dispatch.
                      (          input.s):00003         ;
                      (          input.s):00004         ; Called from the Vbord ISR each frame. Scans all 8 PIA1 columns into a
                      (          input.s):00005         ; local cur[] buffer, compares each key_table entry's (col, row_bit) against
                      (          input.s):00006         ; tester_kbd_prev[col] -> cur[col] for a high-to-low transition (new press),
                      (          input.s):00007         ; and dispatches the matching handler. Updates tester_kbd_prev[] at the end
                      (          input.s):00008         ; so the next scan sees this frame as the baseline.
                      (          input.s):00009         ;
                      (          input.s):00010         ; Assumes PIA1 was left by the BASIC reset-init in keyboard-ready state:
                      (          input.s):00011         ; DRB ($FF02) output (column drive), DRA ($FF00) input (rows), CRA/CRB
                      (          input.s):00012         ; configured for direct data-register access. diag_minimal made the same
                      (          input.s):00013         ; assumption successfully under cart-autorun.
                      (          input.s):00014         ;==============================================================================
                      (          input.s):00015         
     FF00             (          input.s):00016         PIA1_DRA  equ $FF00
     FF02             (          input.s):00017         PIA1_DRB  equ $FF02
                      (          input.s):00018         
                      (          input.s):00019         ; key_table record layout: { col_idx, row_mask, handler_addr }
     0000             (          input.s):00020         KCOL  equ 0
     0001             (          input.s):00021         KROW  equ 1
     0002             (          input.s):00022         KHND  equ 2
     0004             (          input.s):00023         K_LEN equ 4
                      (          input.s):00024         
                      (          input.s):00025         ;------------------------------------------------------------------------------
                      (          input.s):00026         ; kbd_scan_and_dispatch — called from Vbord ISR.
                      (          input.s):00027         ;
                      (          input.s):00028         ;  Inputs:  tester_kbd_prev[0..7]
                      (          input.s):00029         ;  Returns: (none)
                      (          input.s):00030         ;  Side effects: PIA1_DRB written 8x; tester_kbd_prev updated; handlers
                      (          input.s):00031         ;                may set tester_selection_dirty + tester_mode_idx +
                      (          input.s):00032         ;                tester_pattern_idx. Uses 8 bytes of stack.
                      (          input.s):00033         ;------------------------------------------------------------------------------
C0C7                  (          input.s):00034         kbd_scan_and_dispatch
C0C7 3278             (          input.s):00035                 leas    -8,s            ; cur[0..7] on stack
C0C9 1F43             (          input.s):00036                 tfr     s,u             ; U = &cur[0]
                      (          input.s):00037         
                      (          input.s):00038                 ; --- scan all 8 columns into cur[] ---
C0CB 5F               (          input.s):00039                 clrb
C0CC 308D004B         (          input.s):00040                 leax    col_drive_table,pcr
C0D0                  (          input.s):00041         ksd_scan
C0D0 A685             (          input.s):00042                 lda     b,x             ; A = ~(1<<col)
C0D2 B7FF02           (          input.s):00043                 sta     PIA1_DRB
C0D5 B6FF00           (          input.s):00044                 lda     PIA1_DRA        ; rows for this column
C0D8 A7C5             (          input.s):00045                 sta     b,u
C0DA 5C               (          input.s):00046                 incb
C0DB C108             (          input.s):00047                 cmpb    #8
C0DD 25F1             (          input.s):00048                 blo     ksd_scan
                      (          input.s):00049         
                      (          input.s):00050                 ; --- dispatch: for each key_table entry, look for a new-press edge ---
C0DF 308D0051         (          input.s):00051                 leax    key_table,pcr
C0E3 C603             (          input.s):00052                 ldb     #N_KEYS
C0E5                  (          input.s):00053         ksd_disp
C0E5 5D               (          input.s):00054                 tstb
C0E6 2721             (          input.s):00055                 beq     ksd_update_prev
C0E8 3404             (          input.s):00056                 pshs    b               ; save remaining entry count
                      (          input.s):00057         
C0EA E684             (          input.s):00058                 ldb     KCOL,x          ; col index
C0EC A6C5             (          input.s):00059                 lda     b,u             ; cur[col]
C0EE 43               (          input.s):00060                 coma                    ; A = ~cur[col]
C0EF 970D             (          input.s):00061                 sta     ksc_scratch     ; stash
C0F1 E684             (          input.s):00062                 ldb     KCOL,x          ; reload col
C0F3 318D410C         (          input.s):00063                 leay    tester_kbd_prev,pcr
C0F7 A6A5             (          input.s):00064                 lda     b,y             ; A = prev[col]
C0F9 940D             (          input.s):00065                 anda    ksc_scratch     ; A = edge mask (high→low bits)
C0FB A401             (          input.s):00066                 anda    KROW,x          ; isolate this entry's row bit
C0FD 2703             (          input.s):00067                 beq     ksd_no_press
C0FF AD9802           (          input.s):00068                 jsr     [KHND,x]
C102                  (          input.s):00069         ksd_no_press
C102 3504             (          input.s):00070                 puls    b               ; restore entry count
C104 3004             (          input.s):00071                 leax    K_LEN,x
C106 5A               (          input.s):00072                 decb
C107 20DC             (          input.s):00073                 bra     ksd_disp
                      (          input.s):00074         
                      (          input.s):00075                 ; --- copy cur[] back to tester_kbd_prev[] ---
C109                  (          input.s):00076         ksd_update_prev
C109 1F31             (          input.s):00077                 tfr     u,x             ; X = &cur[0]
C10B 318D40F4         (          input.s):00078                 leay    tester_kbd_prev,pcr
C10F C608             (          input.s):00079                 ldb     #8
C111                  (          input.s):00080         ksd_copy
C111 A680             (          input.s):00081                 lda     ,x+
C113 A7A0             (          input.s):00082                 sta     ,y+
C115 5A               (          input.s):00083                 decb
C116 26F9             (          input.s):00084                 bne     ksd_copy
                      (          input.s):00085         
C118 3268             (          input.s):00086                 leas    8,s             ; release cur buffer
C11A 39               (          input.s):00087                 rts
                      (          input.s):00088         
                      (          input.s):00089         ;------------------------------------------------------------------------------
                      (          input.s):00090         ; Column-drive lookup: ~(1<<col) for col 0..7.
                      (          input.s):00091         ;------------------------------------------------------------------------------
C11B                  (          input.s):00092         col_drive_table
C11B FE               (          input.s):00093                 fcb     $FE             ; col 0
C11C FD               (          input.s):00094                 fcb     $FD             ; col 1
C11D FB               (          input.s):00095                 fcb     $FB             ; col 2
C11E F7               (          input.s):00096                 fcb     $F7             ; col 3
C11F EF               (          input.s):00097                 fcb     $EF             ; col 4
C120 DF               (          input.s):00098                 fcb     $DF             ; col 5
