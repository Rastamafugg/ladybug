                      (c/tester/tester.s):00143                 include "pat_bars.s"
                      (       pat_bars.s):00001         ;==============================================================================
                      (       pat_bars.s):00002         ; pat_bars.s — Horizontal 16-color bars pattern.
                      (       pat_bars.s):00003         ;
                      (       pat_bars.s):00004         ; Lifted from src/diag_minimal.s. 16 stripes × 12 rows, each row 160 bytes
                      (       pat_bars.s):00005         ; (320 px / 2 px-per-byte). Stripe N is filled with byte $NN so both pixels
                      (       pat_bars.s):00006         ; land on palette index N.
                      (       pat_bars.s):00007         ;==============================================================================
                      (       pat_bars.s):00008         
                      (       pat_bars.s):00009         ;------------------------------------------------------------------------------
                      (       pat_bars.s):00010         ; pat_bars_draw — fill the framebuffer with 16 horizontal bars.
                      (       pat_bars.s):00011         ;
                      (       pat_bars.s):00012         ;  Inputs:  (none)
                      (       pat_bars.s):00013         ;  Returns: (none)
                      (       pat_bars.s):00014         ;  Side effects: writes FB at $2000..$97FF; clobbers A,B,X,Y,U,CC.
                      (       pat_bars.s):00015         ;------------------------------------------------------------------------------
C140                  (       pat_bars.s):00016         pat_bars_draw
C140 8E2000           (       pat_bars.s):00017                 ldx     #FB_VIRT
C143 CE0000           (       pat_bars.s):00018                 ldu     #$0000          ; pixel-pair byte = $NN for stripe N
C146 4F               (       pat_bars.s):00019                 clra                    ; stripe counter
C147                  (       pat_bars.s):00020         bars_outer
C147 3402             (       pat_bars.s):00021                 pshs    a
C149 108E03C0         (       pat_bars.s):00022                 ldy     #960            ; 12 rows × 80 STDs/row = 960 STDs per stripe
C14D 1F30             (       pat_bars.s):00023                 tfr     u,d
C14F                  (       pat_bars.s):00024         bars_inner
C14F ED81             (       pat_bars.s):00025                 std     ,x++
C151 313F             (       pat_bars.s):00026                 leay    -1,y
C153 26FA             (       pat_bars.s):00027                 bne     bars_inner
C155 33C91111         (       pat_bars.s):00028                 leau    $1111,u         ; next stripe byte ($11 increment in both nibbles)
C159 3502             (       pat_bars.s):00029                 puls    a
C15B 4C               (       pat_bars.s):00030                 inca
C15C 8110             (       pat_bars.s):00031                 cmpa    #16
C15E 25E7             (       pat_bars.s):00032                 blo     bars_outer
C160 39               (       pat_bars.s):00033                 rts
                      (c/tester/tester.s):00144                 include "pat_check.s"
                      (      pat_check.s):00001         ;==============================================================================
                      (      pat_check.s):00002         ; pat_check.s — Checkerboard pattern.
                      (      pat_check.s):00003         ;
                      (      pat_check.s):00004         ; Per WS-A architect spec: alternating $01/$10 bytes across each row, with
                      (      pat_check.s):00005         ; the row's byte-order flipped every 8 scanlines. Each byte holds two pixels
                      (      pat_check.s):00006         ; in palette indices 0 and 1; flipping the byte order flips the pixel-pair
                      (      pat_check.s):00007         ; phase, producing visible 8-row × 2-pixel cells useful as a pixel-alignment
                      (      pat_check.s):00008         ; check against the bars pattern.
                      (      pat_check.s):00009         ;==============================================================================
                      (      pat_check.s):00010         
                      (      pat_check.s):00011         ;------------------------------------------------------------------------------
                      (      pat_check.s):00012         ; pat_check_draw — fill FB with the checkerboard pattern.
                      (      pat_check.s):00013         ;
                      (      pat_check.s):00014         ;  Inputs:  (none)
                      (      pat_check.s):00015         ;  Returns: (none)
                      (      pat_check.s):00016         ;  Side effects: writes FB $2000..$97FF; clobbers A,B,X,Y,U,CC.
                      (      pat_check.s):00017         ;------------------------------------------------------------------------------
C161                  (      pat_check.s):00018         pat_check_draw
C161 8E2000           (      pat_check.s):00019                 ldx     #FB_VIRT
C164 4F               (      pat_check.s):00020                 clra                    ; row counter 0..191
C165                  (      pat_check.s):00021         chk_row
                      (      pat_check.s):00022                 ; Strip parity: bit 3 of row → alternate every 8 rows.
C165 1F89             (      pat_check.s):00023                 tfr     a,b
C167 C408             (      pat_check.s):00024                 andb    #$08
C169 2705             (      pat_check.s):00025                 beq     chk_a
C16B CE1001           (      pat_check.s):00026                 ldu     #$1001          ; row pattern B: $10 $01 $10 $01 ...
C16E 2003             (      pat_check.s):00027                 bra     chk_emit
C170                  (      pat_check.s):00028         chk_a
C170 CE0110           (      pat_check.s):00029                 ldu     #$0110          ; row pattern A: $01 $10 $01 $10 ...
C173                  (      pat_check.s):00030         chk_emit
C173 3402             (      pat_check.s):00031                 pshs    a               ; save row counter
C175 108E0050         (      pat_check.s):00032                 ldy     #80             ; 160 bytes / row = 80 stds
C179 1F30             (      pat_check.s):00033                 tfr     u,d
C17B                  (      pat_check.s):00034         chk_inner
C17B ED81             (      pat_check.s):00035                 std     ,x++
C17D 313F             (      pat_check.s):00036                 leay    -1,y
C17F 26FA             (      pat_check.s):00037                 bne     chk_inner
C181 3502             (      pat_check.s):00038                 puls    a
C183 4C               (      pat_check.s):00039                 inca
C184 81C0             (      pat_check.s):00040                 cmpa    #192
C186 25DD             (      pat_check.s):00041                 blo     chk_row
C188 39               (      pat_check.s):00042                 rts
