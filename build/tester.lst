C136 C123             (          input.s):00132                 fdb     key_mode0
C138 02               (          input.s):00133                 fcb     2               ; 'B' — col 2
C139 01               (          input.s):00134                 fcb     $01             ;       row bit PA0
C13A C128             (          input.s):00135                 fdb     key_pat_bars
C13C 03               (          input.s):00136                 fcb     3               ; 'C' — col 3
C13D 01               (          input.s):00137                 fcb     $01             ;       row bit PA0
C13E C12D             (          input.s):00138                 fdb     key_pat_check
C140                  (          input.s):00139         key_table_end
