                      (          input.s):00123         ; key_table — (col, row_bit, handler) records.
                      (          input.s):00124         ; v0 bindings per WS-A spec:
                      (          input.s):00125         ;   '1' (col 1, row bit PA4=$10) → select mode 0
                      (          input.s):00126         ;   'B' (col 2, row bit PA0=$01) → select pattern 0 (bars)
                      (          input.s):00127         ;   'C' (col 3, row bit PA0=$01) → select pattern 1 (checkerboard)
                      (          input.s):00128         ;==============================================================================
C134                  (          input.s):00129         key_table
C134 01               (          input.s):00130                 fcb     1               ; '1' — col 1
