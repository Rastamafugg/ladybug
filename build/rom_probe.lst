                      (  src/rom_probe.s):00006         ;
                      (  src/rom_probe.s):00007         ; Output:
                      (  src/rom_probe.s):00008         ;   $01FF = mismatch count
                      (  src/rom_probe.s):00009         ;   $0200 onward = records of 4 bytes each:
                      (  src/rom_probe.s):00010         ;       address high, address low, expected byte, actual byte
