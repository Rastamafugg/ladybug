                      (  src/rom_probe.s):00001         ; Minimal cartridge-window read probe.
                      (  src/rom_probe.s):00002         ;
                      (  src/rom_probe.s):00003         ; Purpose:
                      (  src/rom_probe.s):00004         ;   Read $C000-$FEFF before this probe writes to that range, compare each byte
                      (  src/rom_probe.s):00005         ;   after the executing probe code with the expected ROM fill pattern, and log
                      (  src/rom_probe.s):00006         ;   mismatches in low RAM.
                      (  src/rom_probe.s):00007         ;
                      (  src/rom_probe.s):00008         ; Output:
                      (  src/rom_probe.s):00009         ;   $01FF = mismatch count
                      (  src/rom_probe.s):00010         ;   $0200 onward = records of 4 bytes each:
                      (  src/rom_probe.s):00011         ;       address high, address low, expected byte, actual byte
                      (  src/rom_probe.s):00012         
