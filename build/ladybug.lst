                      (adybug/src/main.s):00001         ;==============================================================================
                      (adybug/src/main.s):00002         ; Ladybug — main.s
                      (adybug/src/main.s):00003         ;==============================================================================
                      (adybug/src/main.s):00004         ; Phase 2.4: render a hand-converted arcade tile to the framebuffer.
                      (adybug/src/main.s):00005         ;
                      (adybug/src/main.s):00006         ; Builds on Phase 2.3 (hi-res 320×192×16 + MMU + palette + IRQ tick) by:
                      (adybug/src/main.s):00007         ;   - Replacing the 16-stripe diagnostic with a black-cleared FB.
                      (adybug/src/main.s):00008         ;   - Reassigning palette indices 1-3 to a 4-colour sub-palette
                      (adybug/src/main.s):00009         ;     (0 black / 1 yellow / 2 blue / 3 white) for the tile.
                      (adybug/src/main.s):00010         ;   - Embedding 32 bytes of 4bpp GIME tile data, hand-converted from
                      (adybug/src/main.s):00011         ;     arcade char #432 (a dense tile that exercises all four pixvals)
                      (adybug/src/main.s):00012         ;     in assets/arcade/chars.json. Pixval->palette mapping is identity.
                      (adybug/src/main.s):00013         ;   - blit_tile: 8 rows x 4 bytes, stride 160.
                      (adybug/src/main.s):00014         ;   - Rendering the tile at three FB positions to validate the
                      (adybug/src/main.s):00015         ;     pipeline end-to-end.
                      (adybug/src/main.s):00016         ;
                      (adybug/src/main.s):00017         ; Visible: black screen with three identical "dot-in-box" tiles.
                      (adybug/src/main.s):00018         ; IRQ tick still runs (proven by FRAMES counter) but no longer paints.
                      (adybug/src/main.s):00019         ;==============================================================================
                      (adybug/src/main.s):00020         
                      (adybug/src/main.s):00021                 pragma  nodollarlocal,6809
                      (adybug/src/main.s):00022         
                      (adybug/src/main.s):00023         ;------------------------------------------------------------------------------
                      (adybug/src/main.s):00024         ; DP allocation (page $02)
                      (adybug/src/main.s):00025         ;------------------------------------------------------------------------------
     02               (adybug/src/main.s):00026                 setdp   $02
                      (adybug/src/main.s):00027         
     0202             (adybug/src/main.s):00028         FRAMES  equ     $0202           ; u16 frame counter
                      (adybug/src/main.s):00029         
                      (adybug/src/main.s):00030         ;------------------------------------------------------------------------------
                      (adybug/src/main.s):00031         ; Hardware
                      (adybug/src/main.s):00032         ;------------------------------------------------------------------------------
     FF00             (adybug/src/main.s):00033         PIA1_DA    equ  $FF00
     FF01             (adybug/src/main.s):00034         PIA1_CRA   equ  $FF01
     FF02             (adybug/src/main.s):00035         PIA1_DB    equ  $FF02
     FF03             (adybug/src/main.s):00036         PIA1_CRB   equ  $FF03
     FF20             (adybug/src/main.s):00037         PIA2_DA    equ  $FF20
     FF21             (adybug/src/main.s):00038         PIA2_CRA   equ  $FF21
     FF22             (adybug/src/main.s):00039         PIA2_DB    equ  $FF22
     FF23             (adybug/src/main.s):00040         PIA2_CRB   equ  $FF23
                      (adybug/src/main.s):00041         
     FF90             (adybug/src/main.s):00042         GIME_INIT0 equ  $FF90
     FF92             (adybug/src/main.s):00043         GIME_IRQEN equ  $FF92
     FF98             (adybug/src/main.s):00044         GIME_VMODE equ  $FF98
     FF99             (adybug/src/main.s):00045         GIME_VRES  equ  $FF99
     FF9A             (adybug/src/main.s):00046         GIME_BORDER equ $FF9A
     FF9D             (adybug/src/main.s):00047         GIME_VOFF1 equ  $FF9D           ; addr bits Y18..Y11
     FF9E             (adybug/src/main.s):00048         GIME_VOFF0 equ  $FF9E           ; addr bits Y10..Y3
     FFA0             (adybug/src/main.s):00049         PAR_EXEC   equ  $FFA0           ; PAR0 of executive set ($FFA0..$FFA7)
     FFB0             (adybug/src/main.s):00050         PAL_BASE   equ  $FFB0
                      (adybug/src/main.s):00051         
     FFD9             (adybug/src/main.s):00052         SAM_FAST   equ  $FFD9
     FFDF             (adybug/src/main.s):00053         SAM_ALLRAM equ  $FFDF
                      (adybug/src/main.s):00054         
     FEF7             (adybug/src/main.s):00055         JT_IRQ     equ  $FEF7
                      (adybug/src/main.s):00056         
                      (adybug/src/main.s):00057         ;------------------------------------------------------------------------------
                      (adybug/src/main.s):00058         ; Memory map (post-Phase-2.3 with MMU on)
                      (adybug/src/main.s):00059         ;------------------------------------------------------------------------------
     2000             (adybug/src/main.s):00060         FB_VIRT    equ  $2000           ; virtual base of framebuffer (PAR1)
     9800             (adybug/src/main.s):00061         FB_END     equ  $9800           ; one past last FB byte (192 rows × 160 B)
     0030             (adybug/src/main.s):00062         FB_PHYS    equ  $30             ; physical page 0 of FB
                      (adybug/src/main.s):00063         
     C000             (adybug/src/main.s):00064         CART_BASE  equ  $C000
     FF00             (adybug/src/main.s):00065         CART_END   equ  $FF00
                      (adybug/src/main.s):00066         
                      (adybug/src/main.s):00067         ;==============================================================================
                      (adybug/src/main.s):00068         ;  Cart ROM
                      (adybug/src/main.s):00069         ;==============================================================================
                      (adybug/src/main.s):00070                 org     $C000
                      (adybug/src/main.s):00071         
C000 444B             (adybug/src/main.s):00072                 fcc     "DK"            ; ROM-pack autostart magic; FIRQ -> $C002
                      (adybug/src/main.s):00073         
                      (adybug/src/main.s):00074         ;==============================================================================
                      (adybug/src/main.s):00075         ; entry
                      (adybug/src/main.s):00076         ;==============================================================================
C002 1A50             (adybug/src/main.s):00077         entry   orcc    #$50            ; mask IRQ + FIRQ
C004 10CE1FFE         (adybug/src/main.s):00078                 lds     #$1FFE          ; stack at top of low RAM page
                      (adybug/src/main.s):00079         
C008 8602             (adybug/src/main.s):00080                 lda     #$02            ; DP = $02
C00A 1F8B             (adybug/src/main.s):00081                 tfr     a,dp
                      (adybug/src/main.s):00082         
                      (adybug/src/main.s):00083                 ; --- Quiet legacy PIA interrupts ---
C00C 4F               (adybug/src/main.s):00084                 clra
C00D B7FF01           (adybug/src/main.s):00085                 sta     PIA1_CRA
C010 B7FF03           (adybug/src/main.s):00086                 sta     PIA1_CRB
C013 B7FF21           (adybug/src/main.s):00087                 sta     PIA2_CRA
C016 B7FF23           (adybug/src/main.s):00088                 sta     PIA2_CRB
C019 B6FF00           (adybug/src/main.s):00089                 lda     PIA1_DA
C01C B6FF02           (adybug/src/main.s):00090                 lda     PIA1_DB
C01F B6FF20           (adybug/src/main.s):00091                 lda     PIA2_DA
C022 B6FF22           (adybug/src/main.s):00092                 lda     PIA2_DB
                      (adybug/src/main.s):00093         
                      (adybug/src/main.s):00094                 ; --- Init0 — legacy mode, ACVC IRQ on, force $FExx, MMU still off ---
C025 86A8             (adybug/src/main.s):00095                 lda     #%10101000
C027 B7FF90           (adybug/src/main.s):00096                 sta     GIME_INIT0
                      (adybug/src/main.s):00097         
                      (adybug/src/main.s):00098                 ; --- Cart-to-shadow-RAM self-copy ---
                      (adybug/src/main.s):00099                 ; XRoar 1.10 returns bad cartridge-window bytes at $C0D9-$C0DB during
                      (adybug/src/main.s):00100                 ; this boot path. Skip that range during copy and keep it as unused
                      (adybug/src/main.s):00101                 ; padding below. See lessons-learned.md.
C02A 8EC000           (adybug/src/main.s):00102                 ldx     #CART_BASE
C02D                  (adybug/src/main.s):00103         copyloop
C02D 8CC0D8           (adybug/src/main.s):00104                 cmpx    #$C0D8
C030 270D             (adybug/src/main.s):00105                 beq     copy_around_xroar_bad_window
C032 EC84             (adybug/src/main.s):00106                 ldd     ,x
C034 ED84             (adybug/src/main.s):00107                 std     ,x
C036 3002             (adybug/src/main.s):00108                 leax    2,x
C038                  (adybug/src/main.s):00109         copy_next
C038 8CFF00           (adybug/src/main.s):00110                 cmpx    #CART_END
C03B 25F0             (adybug/src/main.s):00111                 blo     copyloop
C03D 2008             (adybug/src/main.s):00112                 bra     copy_done
                      (adybug/src/main.s):00113         
C03F                  (adybug/src/main.s):00114         copy_around_xroar_bad_window
C03F A684             (adybug/src/main.s):00115                 lda     ,x              ; $C0D8 is reliable; $C0D9-$C0DB are not.
C041 A784             (adybug/src/main.s):00116                 sta     ,x
C043 3004             (adybug/src/main.s):00117                 leax    4,x
C045 20F1             (adybug/src/main.s):00118                 bra     copy_next
                      (adybug/src/main.s):00119         
C047                  (adybug/src/main.s):00120         copy_done
                      (adybug/src/main.s):00121                 ;----------------------------------------------------------------------
                      (adybug/src/main.s):00122                 ; Boot ordering: PARs BEFORE SAM_ALLRAM so par_table reads from ROM.
                      (adybug/src/main.s):00123                 ;----------------------------------------------------------------------
                      (adybug/src/main.s):00124         
                      (adybug/src/main.s):00125                 ; --- Force executive PAR set ($FFA0-$FFA7) to be active ---
C047 7FFF91           (adybug/src/main.s):00126                 clr     $FF91
                      (adybug/src/main.s):00127         
                      (adybug/src/main.s):00128                 ; --- Set up MMU PARs (executive set) ---
                      (adybug/src/main.s):00129                 ; PAR0 ($0000) = phys $38   low RAM (DP, stack)
                      (adybug/src/main.s):00130                 ; PAR1 ($2000) = phys $30   FB page 0
                      (adybug/src/main.s):00131                 ; PAR2 ($4000) = phys $31   FB page 1
                      (adybug/src/main.s):00132                 ; PAR3 ($6000) = phys $32   FB page 2
                      (adybug/src/main.s):00133                 ; PAR4 ($8000) = phys $33   FB page 3
                      (adybug/src/main.s):00134                 ; PAR5 ($A000) = phys $3D   game state (Phase 4+)
                      (adybug/src/main.s):00135                 ; PAR6 ($C000) = phys $3E   code low half
                      (adybug/src/main.s):00136                 ; PAR7 ($E000) = phys $3F   code high half + IO + jump table
C04A 308D00B0         (adybug/src/main.s):00137                 leax    par_table,pcr
C04E 108EFFA0         (adybug/src/main.s):00138                 ldy     #PAR_EXEC
C052 C608             (adybug/src/main.s):00139                 ldb     #8
C054 A680             (adybug/src/main.s):00140         parloop lda     ,x+
C056 A7A0             (adybug/src/main.s):00141                 sta     ,y+
C058 5A               (adybug/src/main.s):00142                 decb
C059 26F9             (adybug/src/main.s):00143                 bne     parloop
                      (adybug/src/main.s):00144         
                      (adybug/src/main.s):00145                 ; --- All-RAM (now safe; PARs already loaded from ROM) ---
C05B B7FFDF           (adybug/src/main.s):00146                 sta     SAM_ALLRAM
                      (adybug/src/main.s):00147         
                      (adybug/src/main.s):00148                 ; --- Fast clock 1.78 MHz ---
C05E B7FFD9           (adybug/src/main.s):00149                 sta     SAM_FAST
                      (adybug/src/main.s):00150         
                      (adybug/src/main.s):00151                 ; --- Set up display (still blanked via CRES=11) ---
C061 8680             (adybug/src/main.s):00152                 lda     #%10000000      ; BP=1 (graphics)
C063 B7FF98           (adybug/src/main.s):00153                 sta     GIME_VMODE
                      (adybug/src/main.s):00154         
C066 861F             (adybug/src/main.s):00155                 lda     #$1F            ; VRES=00 HRES=111 CRES=11 (BLANKED)
C068 B7FF99           (adybug/src/main.s):00156                 sta     GIME_VRES
                      (adybug/src/main.s):00157         
C06B 8628             (adybug/src/main.s):00158                 lda     #$28            ; bright border (empirically "pink") so a black
C06D B7FF9A           (adybug/src/main.s):00159                 sta     GIME_BORDER     ;   stripe 0 is visually distinct from the border
                      (adybug/src/main.s):00160         
                      (adybug/src/main.s):00161                 ; FB at phys $30 → physical address $060000.
                      (adybug/src/main.s):00162                 ;   Y18=1, Y17=1, Y16..Y3 = 0
                      (adybug/src/main.s):00163                 ;   V1 ($FF9D) = Y18..Y11 = %11000000 = $C0
                      (adybug/src/main.s):00164                 ;   V0 ($FF9E) = Y10..Y3  = $00
C070 86C0             (adybug/src/main.s):00165                 lda     #$C0
C072 B7FF9D           (adybug/src/main.s):00166                 sta     GIME_VOFF1
C075 7FFF9E           (adybug/src/main.s):00167                 clr     GIME_VOFF0
                      (adybug/src/main.s):00168         
                      (adybug/src/main.s):00169                 ; --- Init0 — turn on MMU + switch to hi-res. Display still blanked. ---
                      (adybug/src/main.s):00170                 ; %01101000 = COCO=0 MMU=1 ACVCIRQ=1 ACVCFIRQ=0 force-$FExx=1 SCS=0 ROMmap=00
C078 8668             (adybug/src/main.s):00171                 lda     #%01101000
C07A B7FF90           (adybug/src/main.s):00172                 sta     GIME_INIT0
                      (adybug/src/main.s):00173         
                      (adybug/src/main.s):00174                 ; --- Load palette (16 entries) ---
C07D 308D0085         (adybug/src/main.s):00175                 leax    palette_table,pcr
C081 108EFFB0         (adybug/src/main.s):00176                 ldy     #PAL_BASE
C085 C610             (adybug/src/main.s):00177                 ldb     #16
C087 A680             (adybug/src/main.s):00178         palloop lda     ,x+
C089 A7A0             (adybug/src/main.s):00179                 sta     ,y+
C08B 5A               (adybug/src/main.s):00180                 decb
C08C 26F9             (adybug/src/main.s):00181                 bne     palloop
                      (adybug/src/main.s):00182         
                      (adybug/src/main.s):00183                 ; --- Clear FB to palette idx 0 (black) ---
                      (adybug/src/main.s):00184                 ; 30720 bytes = 15360 STDs.
C08E 8E2000           (adybug/src/main.s):00185                 ldx     #FB_VIRT
C091 CC0000           (adybug/src/main.s):00186                 ldd     #$0000
C094 ED81             (adybug/src/main.s):00187         clr_fb  std     ,x++
C096 8C9800           (adybug/src/main.s):00188                 cmpx    #FB_END
C099 25F9             (adybug/src/main.s):00189                 blo     clr_fb
                      (adybug/src/main.s):00190         
                      (adybug/src/main.s):00191                 ; --- ISOLATION STEP G: single blit at FB_VIRT (top-left) ---
C09B 8E2000           (adybug/src/main.s):00192                 ldx     #FB_VIRT
C09E 17003D           (adybug/src/main.s):00193                 lbsr    blit_tile
                      (adybug/src/main.s):00194         
                      (adybug/src/main.s):00195                 ; Un-blank: CRES=10 (16-color)
C0A1 861E             (adybug/src/main.s):00196                 lda     #$1E
C0A3 B7FF99           (adybug/src/main.s):00197                 sta     GIME_VRES
C0A6                  (adybug/src/main.s):00198         post_blit
C0A6 20FE             (adybug/src/main.s):00199                 bra     post_blit       ; halt
                      (adybug/src/main.s):00200         
                      (adybug/src/main.s):00201                 ; --- Un-blank: CRES=10 (16-color) ---
C0A8 861E             (adybug/src/main.s):00202                 lda     #$1E
C0AA B7FF99           (adybug/src/main.s):00203                 sta     GIME_VRES
                      (adybug/src/main.s):00204         
                      (adybug/src/main.s):00205                 ; --- IRQ handler at $FEF7 jump-table slot ---
C0AD 867E             (adybug/src/main.s):00206                 lda     #$7E            ; JMP extended
C0AF B7FEF7           (adybug/src/main.s):00207                 sta     JT_IRQ
C0B2 CCC0F4           (adybug/src/main.s):00208                 ldd     #irq_handler
C0B5 FDFEF8           (adybug/src/main.s):00209                 std     JT_IRQ+1
                      (adybug/src/main.s):00210         
C0B8 0F02             (adybug/src/main.s):00211                 clr     FRAMES
C0BA 0F03             (adybug/src/main.s):00212                 clr     FRAMES+1
                      (adybug/src/main.s):00213         
                      (adybug/src/main.s):00214                 ; --- Enable Vbord ---
C0BC 8608             (adybug/src/main.s):00215                 lda     #%00001000
C0BE B7FF92           (adybug/src/main.s):00216                 sta     GIME_IRQEN
C0C1 B6FF92           (adybug/src/main.s):00217                 lda     GIME_IRQEN
                      (adybug/src/main.s):00218         
C0C4 1CEF             (adybug/src/main.s):00219                 andcc   #%11101111      ; unmask IRQ
                      (adybug/src/main.s):00220         
                      (adybug/src/main.s):00221         ;==============================================================================
                      (adybug/src/main.s):00222         ; mainloop — IRQ keeps ticking FRAMES; CPU just spins.
                      (adybug/src/main.s):00223         ;==============================================================================
C0C6                  (adybug/src/main.s):00224         mainloop
C0C6 13               (adybug/src/main.s):00225                 sync
C0C7 20FD             (adybug/src/main.s):00226                 bra     mainloop
                      (adybug/src/main.s):00227         
                      (adybug/src/main.s):00228                 ; XRoar 1.10 returns bad cartridge-window reads at $C0D9-$C0DB.
                      (adybug/src/main.s):00229                 ; Keep that absolute range inside explicit unused padding so the copy
                      (adybug/src/main.s):00230                 ; skip cannot omit live code or data. The next routine starts after
                      (adybug/src/main.s):00231                 ; the unreliable range.
C0C9 1212121212121212 (adybug/src/main.s):00232                 fill    $12,$15         ; NOP padding
     1212121212121212
     1212121212
                      (adybug/src/main.s):00233         
                      (adybug/src/main.s):00234         ;==============================================================================
                      (adybug/src/main.s):00235         ; blit_tile — copy an 8x8 tile (32 bytes, 4bpp packed) to the framebuffer.
                      (adybug/src/main.s):00236         ;   X = dest FB byte address (top-left of tile)
                      (adybug/src/main.s):00237         ;   Y = source tile data
                      (adybug/src/main.s):00238         ; Trashes A, B, D, X, Y. 8 rows x 4 bytes; row stride 160 (FB) - 4 (written) = 156.
                      (adybug/src/main.s):00239         ;==============================================================================
C0DE                  (adybug/src/main.s):00240         blit_tile
                      (adybug/src/main.s):00241                 ; B counter, hardcoded $1111. ldd would clobber B, so reload B
                      (adybug/src/main.s):00242                 ; from a DP byte each iter. Pure loop + FB write test.
C0DE 8608             (adybug/src/main.s):00243                 lda     #8
C0E0 B70005           (adybug/src/main.s):00244                 sta     $05             ; DP counter at $0205
C0E3 CC1111           (adybug/src/main.s):00245         btrow   ldd     #$1111
C0E6 ED81             (adybug/src/main.s):00246                 std     ,x++
C0E8 ED81             (adybug/src/main.s):00247                 std     ,x++
C0EA 3089009C         (adybug/src/main.s):00248                 leax    156,x
C0EE 7A0005           (adybug/src/main.s):00249                 dec     $05
C0F1 26F0             (adybug/src/main.s):00250                 bne     btrow
C0F3 39               (adybug/src/main.s):00251                 rts
                      (adybug/src/main.s):00252         
                      (adybug/src/main.s):00253         ;==============================================================================
                      (adybug/src/main.s):00254         ; irq_handler — Vbord (60 Hz)
                      (adybug/src/main.s):00255         ;==============================================================================
C0F4                  (adybug/src/main.s):00256         irq_handler
C0F4 B6FF92           (adybug/src/main.s):00257                 lda     GIME_IRQEN
C0F7 0C03             (adybug/src/main.s):00258                 inc     FRAMES+1
C0F9 2602             (adybug/src/main.s):00259                 bne     irq_done
C0FB 0C02             (adybug/src/main.s):00260                 inc     FRAMES
C0FD                  (adybug/src/main.s):00261         irq_done
C0FD 3B               (adybug/src/main.s):00262                 rti
                      (adybug/src/main.s):00263         
                      (adybug/src/main.s):00264         ;==============================================================================
                      (adybug/src/main.s):00265         ; Data tables (in cart ROM, copied to RAM by the boot self-copy)
                      (adybug/src/main.s):00266         ;==============================================================================
                      (adybug/src/main.s):00267         
                      (adybug/src/main.s):00268         ;-- PAR values for executive set (PAR0..PAR7) ---------------------------------
C0FE                  (adybug/src/main.s):00269         par_table
C0FE 38303132333D3E3F (adybug/src/main.s):00270                 fcb     $38,$30,$31,$32,$33,$3D,$3E,$3F
                      (adybug/src/main.s):00271         
                      (adybug/src/main.s):00272         ;-- Palette: 16 entries, GIME 6-bit codes (composite-NTSC empirical). --------
                      (adybug/src/main.s):00273         ;   Indices 0-3 form the sub-palette for the Phase 2.4 test tile:
                      (adybug/src/main.s):00274         ;     0 black, 1 yellow, 2 blue, 3 white. Remaining slots unused for now.
C106                  (adybug/src/main.s):00275         palette_table
C106 00               (adybug/src/main.s):00276                 fcb     $00             ; 0  black
C107 33               (adybug/src/main.s):00277                 fcb     $33             ; 1  yellow
C108 0C               (adybug/src/main.s):00278                 fcb     $0C             ; 2  blue
C109 3F               (adybug/src/main.s):00279                 fcb     $3F             ; 3  white
C10A 03               (adybug/src/main.s):00280                 fcb     $03             ; 4  green-brown (unused)
C10B 30               (adybug/src/main.s):00281                 fcb     $30             ; 5  white-dup   (unused)
C10C 0F               (adybug/src/main.s):00282                 fcb     $0F             ; 6  forest grn  (unused)
C10D 3C               (adybug/src/main.s):00283                 fcb     $3C             ; 7  baby blue   (unused)
C10E 20               (adybug/src/main.s):00284                 fcb     $20             ; 8  grey        (unused)
C10F 08               (adybug/src/main.s):00285                 fcb     $08             ; 9  fuchsia     (unused)
C110 02               (adybug/src/main.s):00286                 fcb     $02             ; 10 darker grn  (unused)
C111 22               (adybug/src/main.s):00287                 fcb     $22             ; 11 sat lt grn  (unused)
C112 0A               (adybug/src/main.s):00288                 fcb     $0A             ; 12 purple     (unused)
C113 28               (adybug/src/main.s):00289                 fcb     $28             ; 13 pink       (unused)
C114 15               (adybug/src/main.s):00290                 fcb     $15             ; 14 orange     (unused)
C115 24               (adybug/src/main.s):00291                 fcb     $24             ; 15 orange-yel (unused)
                      (adybug/src/main.s):00292         
                      (adybug/src/main.s):00293         ;-- Test tile: arcade chars.json[432] (dense, uses all four pixvals). --------
                      (adybug/src/main.s):00294         ;   Hand-converted from 8x8 2bpp pixval grid to 4bpp GIME packing
