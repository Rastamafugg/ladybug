                      (adybug/src/main.s):00001         ;==============================================================================
                      (adybug/src/main.s):00002         ; Ladybug — main.s
                      (adybug/src/main.s):00003         ;==============================================================================
                      (adybug/src/main.s):00004         ; Phase 2.4: render a hand-converted arcade tile to the framebuffer.
                      (adybug/src/main.s):00005         ;
                      (adybug/src/main.s):00006         ; Builds on Phase 2.3 (hi-res 320×192×16 + MMU + palette + IRQ tick) by:
                      (adybug/src/main.s):00007         ;   - Replacing the 16-stripe diagnostic with a black-cleared FB.
                      (adybug/src/main.s):00008         ;   - Reassigning palette indices 1-3 to a 4-colour sub-palette
                      (adybug/src/main.s):00009         ;     (0 black / 1 yellow / 2 blue / 3 white) for the tile.
                      (adybug/src/main.s):00010         ;   - Embedding 32 bytes of 4bpp GIME tile data, hand-converted from
                      (adybug/src/main.s):00011         ;     arcade char #432 (a dense tile that exercises all four pixvals)
                      (adybug/src/main.s):00012         ;     in assets/arcade/chars.json. Pixval->palette mapping is identity.
                      (adybug/src/main.s):00013         ;   - blit_tile: 8 rows x 4 bytes, stride 160.
                      (adybug/src/main.s):00014         ;   - Rendering the tile at three FB positions to validate the
                      (adybug/src/main.s):00015         ;     pipeline end-to-end.
                      (adybug/src/main.s):00016         ;
                      (adybug/src/main.s):00017         ; Visible: black screen with three identical "dot-in-box" tiles.
                      (adybug/src/main.s):00018         ; IRQ tick still runs (proven by FRAMES counter) but no longer paints.
                      (adybug/src/main.s):00019         ;==============================================================================
                      (adybug/src/main.s):00020         
                      (adybug/src/main.s):00021                 pragma  nodollarlocal,6809
                      (adybug/src/main.s):00022         
                      (adybug/src/main.s):00023         ;------------------------------------------------------------------------------
                      (adybug/src/main.s):00024         ; DP allocation (page $02)
                      (adybug/src/main.s):00025         ;------------------------------------------------------------------------------
     02               (adybug/src/main.s):00026                 setdp   $02
                      (adybug/src/main.s):00027         
     0202             (adybug/src/main.s):00028         FRAMES  equ     $0202           ; u16 frame counter
                      (adybug/src/main.s):00029         
                      (adybug/src/main.s):00030         ;------------------------------------------------------------------------------
                      (adybug/src/main.s):00031         ; Hardware
                      (adybug/src/main.s):00032         ;------------------------------------------------------------------------------
     FF00             (adybug/src/main.s):00033         PIA1_DA    equ  $FF00
     FF01             (adybug/src/main.s):00034         PIA1_CRA   equ  $FF01
     FF02             (adybug/src/main.s):00035         PIA1_DB    equ  $FF02
     FF03             (adybug/src/main.s):00036         PIA1_CRB   equ  $FF03
     FF20             (adybug/src/main.s):00037         PIA2_DA    equ  $FF20
     FF21             (adybug/src/main.s):00038         PIA2_CRA   equ  $FF21
     FF22             (adybug/src/main.s):00039         PIA2_DB    equ  $FF22
     FF23             (adybug/src/main.s):00040         PIA2_CRB   equ  $FF23
                      (adybug/src/main.s):00041         
     FF90             (adybug/src/main.s):00042         GIME_INIT0 equ  $FF90
     FF92             (adybug/src/main.s):00043         GIME_IRQEN equ  $FF92
     FF98             (adybug/src/main.s):00044         GIME_VMODE equ  $FF98
     FF99             (adybug/src/main.s):00045         GIME_VRES  equ  $FF99
     FF9A             (adybug/src/main.s):00046         GIME_BORDER equ $FF9A
     FF9D             (adybug/src/main.s):00047         GIME_VOFF1 equ  $FF9D           ; addr bits Y18..Y11
     FF9E             (adybug/src/main.s):00048         GIME_VOFF0 equ  $FF9E           ; addr bits Y10..Y3
     FFA0             (adybug/src/main.s):00049         PAR_EXEC   equ  $FFA0           ; PAR0 of executive set ($FFA0..$FFA7)
     FFB0             (adybug/src/main.s):00050         PAL_BASE   equ  $FFB0
                      (adybug/src/main.s):00051         
     FFD9             (adybug/src/main.s):00052         SAM_FAST   equ  $FFD9
     FFDF             (adybug/src/main.s):00053         SAM_ALLRAM equ  $FFDF
                      (adybug/src/main.s):00054         
     FEF7             (adybug/src/main.s):00055         JT_IRQ     equ  $FEF7
                      (adybug/src/main.s):00056         
                      (adybug/src/main.s):00057         ;------------------------------------------------------------------------------
                      (adybug/src/main.s):00058         ; Memory map (post-Phase-2.3 with MMU on)
                      (adybug/src/main.s):00059         ;------------------------------------------------------------------------------
     2000             (adybug/src/main.s):00060         FB_VIRT    equ  $2000           ; virtual base of framebuffer (PAR1)
     9800             (adybug/src/main.s):00061         FB_END     equ  $9800           ; one past last FB byte (192 rows × 160 B)
     0030             (adybug/src/main.s):00062         FB_PHYS    equ  $30             ; physical page 0 of FB
                      (adybug/src/main.s):00063         
     C000             (adybug/src/main.s):00064         CART_BASE  equ  $C000
     FF00             (adybug/src/main.s):00065         CART_END   equ  $FF00
                      (adybug/src/main.s):00066         
                      (adybug/src/main.s):00067         ;==============================================================================
                      (adybug/src/main.s):00068         ;  Cart ROM
                      (adybug/src/main.s):00069         ;==============================================================================
                      (adybug/src/main.s):00070                 org     $C000
                      (adybug/src/main.s):00071         
C000 444B             (adybug/src/main.s):00072                 fcc     "DK"            ; ROM-pack autostart magic; FIRQ -> $C002
                      (adybug/src/main.s):00073         
                      (adybug/src/main.s):00074         ;==============================================================================
                      (adybug/src/main.s):00075         ; entry
                      (adybug/src/main.s):00076         ;==============================================================================
C002 1A50             (adybug/src/main.s):00077         entry   orcc    #$50            ; mask IRQ + FIRQ
C004 10CE1FFE         (adybug/src/main.s):00078                 lds     #$1FFE          ; stack at top of low RAM page
                      (adybug/src/main.s):00079         
C008 8602             (adybug/src/main.s):00080                 lda     #$02            ; DP = $02
C00A 1F8B             (adybug/src/main.s):00081                 tfr     a,dp
                      (adybug/src/main.s):00082         
                      (adybug/src/main.s):00083                 ; --- Quiet legacy PIA interrupts ---
C00C 4F               (adybug/src/main.s):00084                 clra
C00D B7FF01           (adybug/src/main.s):00085                 sta     PIA1_CRA
C010 B7FF03           (adybug/src/main.s):00086                 sta     PIA1_CRB
C013 B7FF21           (adybug/src/main.s):00087                 sta     PIA2_CRA
C016 B7FF23           (adybug/src/main.s):00088                 sta     PIA2_CRB
C019 B6FF00           (adybug/src/main.s):00089                 lda     PIA1_DA
C01C B6FF02           (adybug/src/main.s):00090                 lda     PIA1_DB
C01F B6FF20           (adybug/src/main.s):00091                 lda     PIA2_DA
C022 B6FF22           (adybug/src/main.s):00092                 lda     PIA2_DB
                      (adybug/src/main.s):00093         
                      (adybug/src/main.s):00094                 ; --- Init0 — legacy mode, ACVC IRQ on, force $FExx, MMU still off ---
C025 86A8             (adybug/src/main.s):00095                 lda     #%10101000
C027 B7FF90           (adybug/src/main.s):00096                 sta     GIME_INIT0
                      (adybug/src/main.s):00097         
                      (adybug/src/main.s):00098                 ; --- Cart-to-shadow-RAM self-copy ---
C02A 8EC000           (adybug/src/main.s):00099                 ldx     #CART_BASE
C02D                  (adybug/src/main.s):00100         copyloop
C02D EC84             (adybug/src/main.s):00101                 ldd     ,x
C02F ED84             (adybug/src/main.s):00102                 std     ,x
C031 3002             (adybug/src/main.s):00103                 leax    2,x
C033 8CFF00           (adybug/src/main.s):00104                 cmpx    #CART_END
C036 25F5             (adybug/src/main.s):00105                 blo     copyloop
                      (adybug/src/main.s):00106         
                      (adybug/src/main.s):00107                 ; --- All-RAM ---
C038 B7FFDF           (adybug/src/main.s):00108                 sta     SAM_ALLRAM
                      (adybug/src/main.s):00109         
                      (adybug/src/main.s):00110                 ; --- Fast clock 1.78 MHz ---
C03B B7FFD9           (adybug/src/main.s):00111                 sta     SAM_FAST
                      (adybug/src/main.s):00112         
                      (adybug/src/main.s):00113                 ;----------------------------------------------------------------------
                      (adybug/src/main.s):00114                 ; Phase 2.3 additions begin here.
                      (adybug/src/main.s):00115                 ;----------------------------------------------------------------------
                      (adybug/src/main.s):00116         
                      (adybug/src/main.s):00117                 ; --- Force executive PAR set ($FFA0-$FFA7) to be active ---
C03E 7FFF91           (adybug/src/main.s):00118                 clr     $FF91
                      (adybug/src/main.s):00119         
                      (adybug/src/main.s):00120                 ; --- Set up MMU PARs (executive set) ---
                      (adybug/src/main.s):00121                 ; PAR0 ($0000) = phys $38   low RAM (DP, stack)
                      (adybug/src/main.s):00122                 ; PAR1 ($2000) = phys $30   FB page 0
                      (adybug/src/main.s):00123                 ; PAR2 ($4000) = phys $31   FB page 1
                      (adybug/src/main.s):00124                 ; PAR3 ($6000) = phys $32   FB page 2
                      (adybug/src/main.s):00125                 ; PAR4 ($8000) = phys $33   FB page 3
                      (adybug/src/main.s):00126                 ; PAR5 ($A000) = phys $3D   game state (Phase 4+)
                      (adybug/src/main.s):00127                 ; PAR6 ($C000) = phys $3E   code low half
                      (adybug/src/main.s):00128                 ; PAR7 ($E000) = phys $3F   code high half + IO + jump table
C041 308D00A9         (adybug/src/main.s):00129                 leax    par_table,pcr
C045 108EFFA0         (adybug/src/main.s):00130                 ldy     #PAR_EXEC
C049 C608             (adybug/src/main.s):00131                 ldb     #8
C04B A680             (adybug/src/main.s):00132         parloop lda     ,x+
C04D A7A0             (adybug/src/main.s):00133                 sta     ,y+
C04F 5A               (adybug/src/main.s):00134                 decb
C050 26F9             (adybug/src/main.s):00135                 bne     parloop
                      (adybug/src/main.s):00136         
                      (adybug/src/main.s):00137                 ; --- Set up display (still blanked via CRES=11) ---
C052 8680             (adybug/src/main.s):00138                 lda     #%10000000      ; BP=1 (graphics)
C054 B7FF98           (adybug/src/main.s):00139                 sta     GIME_VMODE
                      (adybug/src/main.s):00140         
C057 861F             (adybug/src/main.s):00141                 lda     #$1F            ; VRES=00 HRES=111 CRES=11 (BLANKED)
C059 B7FF99           (adybug/src/main.s):00142                 sta     GIME_VRES
                      (adybug/src/main.s):00143         
C05C 8628             (adybug/src/main.s):00144                 lda     #$28            ; bright border (empirically "pink") so a black
C05E B7FF9A           (adybug/src/main.s):00145                 sta     GIME_BORDER     ;   stripe 0 is visually distinct from the border
                      (adybug/src/main.s):00146         
                      (adybug/src/main.s):00147                 ; FB at phys $30 → physical address $060000.
                      (adybug/src/main.s):00148                 ;   Y18=1, Y17=1, Y16..Y3 = 0
                      (adybug/src/main.s):00149                 ;   V1 ($FF9D) = Y18..Y11 = %11000000 = $C0
                      (adybug/src/main.s):00150                 ;   V0 ($FF9E) = Y10..Y3  = $00
C061 86C0             (adybug/src/main.s):00151                 lda     #$C0
C063 B7FF9D           (adybug/src/main.s):00152                 sta     GIME_VOFF1
C066 7FFF9E           (adybug/src/main.s):00153                 clr     GIME_VOFF0
                      (adybug/src/main.s):00154         
                      (adybug/src/main.s):00155                 ; --- Init0 — turn on MMU + switch to hi-res. Display still blanked. ---
                      (adybug/src/main.s):00156                 ; %01101000 = COCO=0 MMU=1 ACVCIRQ=1 ACVCFIRQ=0 force-$FExx=1 SCS=0 ROMmap=00
C069 8668             (adybug/src/main.s):00157                 lda     #%01101000
C06B B7FF90           (adybug/src/main.s):00158                 sta     GIME_INIT0
                      (adybug/src/main.s):00159         
                      (adybug/src/main.s):00160                 ; --- Load palette (16 entries) ---
C06E 308D0084         (adybug/src/main.s):00161                 leax    palette_table,pcr
C072 108EFFB0         (adybug/src/main.s):00162                 ldy     #PAL_BASE
C076 C610             (adybug/src/main.s):00163                 ldb     #16
C078 A680             (adybug/src/main.s):00164         palloop lda     ,x+
C07A A7A0             (adybug/src/main.s):00165                 sta     ,y+
C07C 5A               (adybug/src/main.s):00166                 decb
C07D 26F9             (adybug/src/main.s):00167                 bne     palloop
                      (adybug/src/main.s):00168         
                      (adybug/src/main.s):00169                 ; --- Clear FB to palette idx 0 (black) ---
                      (adybug/src/main.s):00170                 ; 30720 bytes = 15360 STDs.
C07F 8E2000           (adybug/src/main.s):00171                 ldx     #FB_VIRT
C082 CC0000           (adybug/src/main.s):00172                 ldd     #$0000
C085 ED81             (adybug/src/main.s):00173         clr_fb  std     ,x++
C087 8C9800           (adybug/src/main.s):00174                 cmpx    #FB_END
C08A 25F9             (adybug/src/main.s):00175                 blo     clr_fb
                      (adybug/src/main.s):00176         
                      (adybug/src/main.s):00177                 ; --- Blit the test tile at three FB positions ---
                      (adybug/src/main.s):00178                 ; Tile = 8 rows x 4 bytes; pos byte offset = row*8*160 + col*4.
C08C 318D0076         (adybug/src/main.s):00179                 leay    tile_data,pcr
C090 8E2A10           (adybug/src/main.s):00180                 ldx     #FB_VIRT+2576           ; tile-row  2, tile-col  4
C093 170035           (adybug/src/main.s):00181                 lbsr    blit_tile
C096 318D006C         (adybug/src/main.s):00182                 leay    tile_data,pcr
C09A 8E5250           (adybug/src/main.s):00183                 ldx     #FB_VIRT+12880          ; tile-row 10, tile-col 20
C09D 17002B           (adybug/src/main.s):00184                 lbsr    blit_tile
C0A0 318D0062         (adybug/src/main.s):00185                 leay    tile_data,pcr
C0A4 8E8490           (adybug/src/main.s):00186                 ldx     #FB_VIRT+25744          ; tile-row 20, tile-col 36
C0A7 170021           (adybug/src/main.s):00187                 lbsr    blit_tile
                      (adybug/src/main.s):00188         
                      (adybug/src/main.s):00189                 ; --- Un-blank: CRES=10 (16-color) ---
C0AA 861E             (adybug/src/main.s):00190                 lda     #$1E
C0AC B7FF99           (adybug/src/main.s):00191                 sta     GIME_VRES
                      (adybug/src/main.s):00192         
                      (adybug/src/main.s):00193                 ; --- IRQ handler at $FEF7 jump-table slot ---
C0AF 867E             (adybug/src/main.s):00194                 lda     #$7E            ; JMP extended
C0B1 B7FEF7           (adybug/src/main.s):00195                 sta     JT_IRQ
C0B4 CCC0E4           (adybug/src/main.s):00196                 ldd     #irq_handler
C0B7 FDFEF8           (adybug/src/main.s):00197                 std     JT_IRQ+1
                      (adybug/src/main.s):00198         
C0BA 0F02             (adybug/src/main.s):00199                 clr     FRAMES
C0BC 0F03             (adybug/src/main.s):00200                 clr     FRAMES+1
                      (adybug/src/main.s):00201         
                      (adybug/src/main.s):00202                 ; --- Enable Vbord ---
C0BE 8608             (adybug/src/main.s):00203                 lda     #%00001000
C0C0 B7FF92           (adybug/src/main.s):00204                 sta     GIME_IRQEN
C0C3 B6FF92           (adybug/src/main.s):00205                 lda     GIME_IRQEN
                      (adybug/src/main.s):00206         
C0C6 1CEF             (adybug/src/main.s):00207                 andcc   #%11101111      ; unmask IRQ
                      (adybug/src/main.s):00208         
                      (adybug/src/main.s):00209         ;==============================================================================
                      (adybug/src/main.s):00210         ; mainloop — IRQ keeps ticking FRAMES; CPU just spins.
                      (adybug/src/main.s):00211         ;==============================================================================
C0C8                  (adybug/src/main.s):00212         mainloop
C0C8 13               (adybug/src/main.s):00213                 sync
C0C9 20FD             (adybug/src/main.s):00214                 bra     mainloop
                      (adybug/src/main.s):00215         
                      (adybug/src/main.s):00216         ;==============================================================================
                      (adybug/src/main.s):00217         ; blit_tile — copy an 8x8 tile (32 bytes, 4bpp packed) to the framebuffer.
                      (adybug/src/main.s):00218         ;   X = dest FB byte address (top-left of tile)
                      (adybug/src/main.s):00219         ;   Y = source tile data
                      (adybug/src/main.s):00220         ; Trashes A, B, D, X, Y. 8 rows x 4 bytes; row stride 160 (FB) - 4 (written) = 156.
                      (adybug/src/main.s):00221         ;==============================================================================
C0CB                  (adybug/src/main.s):00222         blit_tile
                      (adybug/src/main.s):00223                 ; 8 rows x 4 bytes, stride 160. Loop ends when Y reaches end of
                      (adybug/src/main.s):00224                 ; tile data; can't use a B counter because `ldd ,y++` clobbers B.
C0CB 33A820           (adybug/src/main.s):00225                 leau    32,y                    ; U = end of tile data
C0CE 3440             (adybug/src/main.s):00226                 pshs    u                       ; stash end addr at ,s for cmpy
C0D0 ECA1             (adybug/src/main.s):00227         btrow   ldd     ,y++
C0D2 ED81             (adybug/src/main.s):00228                 std     ,x++
C0D4 ECA1             (adybug/src/main.s):00229                 ldd     ,y++
C0D6 ED81             (adybug/src/main.s):00230                 std     ,x++
C0D8 3089009C         (adybug/src/main.s):00231                 leax    156,x                   ; advance X to next FB row
C0DC 10ACE4           (adybug/src/main.s):00232                 cmpy    ,s                      ; Y reached end?
C0DF 25EF             (adybug/src/main.s):00233                 blo     btrow
C0E1 3262             (adybug/src/main.s):00234                 leas    2,s                     ; drop end addr
C0E3 39               (adybug/src/main.s):00235                 rts
                      (adybug/src/main.s):00236         
                      (adybug/src/main.s):00237         ;==============================================================================
                      (adybug/src/main.s):00238         ; irq_handler — Vbord (60 Hz)
                      (adybug/src/main.s):00239         ;==============================================================================
C0E4                  (adybug/src/main.s):00240         irq_handler
C0E4 B6FF92           (adybug/src/main.s):00241                 lda     GIME_IRQEN
C0E7 0C03             (adybug/src/main.s):00242                 inc     FRAMES+1
C0E9 2602             (adybug/src/main.s):00243                 bne     irq_done
C0EB 0C02             (adybug/src/main.s):00244                 inc     FRAMES
C0ED                  (adybug/src/main.s):00245         irq_done
C0ED 3B               (adybug/src/main.s):00246                 rti
                      (adybug/src/main.s):00247         
                      (adybug/src/main.s):00248         ;==============================================================================
                      (adybug/src/main.s):00249         ; Data tables (in cart ROM, copied to RAM by the boot self-copy)
                      (adybug/src/main.s):00250         ;==============================================================================
                      (adybug/src/main.s):00251         
                      (adybug/src/main.s):00252         ;-- PAR values for executive set (PAR0..PAR7) ---------------------------------
C0EE                  (adybug/src/main.s):00253         par_table
C0EE 38303132333D3E3F (adybug/src/main.s):00254                 fcb     $38,$30,$31,$32,$33,$3D,$3E,$3F
                      (adybug/src/main.s):00255         
                      (adybug/src/main.s):00256         ;-- Palette: 16 entries, GIME 6-bit codes (composite-NTSC empirical). --------
                      (adybug/src/main.s):00257         ;   Indices 0-3 form the sub-palette for the Phase 2.4 test tile:
                      (adybug/src/main.s):00258         ;     0 black, 1 yellow, 2 blue, 3 white. Remaining slots unused for now.
C0F6                  (adybug/src/main.s):00259         palette_table
C0F6 00               (adybug/src/main.s):00260                 fcb     $00             ; 0  black
C0F7 33               (adybug/src/main.s):00261                 fcb     $33             ; 1  yellow
C0F8 0C               (adybug/src/main.s):00262                 fcb     $0C             ; 2  blue
C0F9 3F               (adybug/src/main.s):00263                 fcb     $3F             ; 3  white
C0FA 03               (adybug/src/main.s):00264                 fcb     $03             ; 4  green-brown (unused)
C0FB 30               (adybug/src/main.s):00265                 fcb     $30             ; 5  white-dup   (unused)
C0FC 0F               (adybug/src/main.s):00266                 fcb     $0F             ; 6  forest grn  (unused)
C0FD 3C               (adybug/src/main.s):00267                 fcb     $3C             ; 7  baby blue   (unused)
C0FE 20               (adybug/src/main.s):00268                 fcb     $20             ; 8  grey        (unused)
C0FF 08               (adybug/src/main.s):00269                 fcb     $08             ; 9  fuchsia     (unused)
C100 02               (adybug/src/main.s):00270                 fcb     $02             ; 10 darker grn  (unused)
C101 22               (adybug/src/main.s):00271                 fcb     $22             ; 11 sat lt grn  (unused)
C102 0A               (adybug/src/main.s):00272                 fcb     $0A             ; 12 purple     (unused)
C103 28               (adybug/src/main.s):00273                 fcb     $28             ; 13 pink       (unused)
C104 15               (adybug/src/main.s):00274                 fcb     $15             ; 14 orange     (unused)
C105 24               (adybug/src/main.s):00275                 fcb     $24             ; 15 orange-yel (unused)
                      (adybug/src/main.s):00276         
                      (adybug/src/main.s):00277         ;-- Test tile: arcade chars.json[432] (dense, uses all four pixvals). --------
                      (adybug/src/main.s):00278         ;   Hand-converted from 8x8 2bpp pixval grid to 4bpp GIME packing
                      (adybug/src/main.s):00279         ;   (2 px/byte, hi-nibble = leftmost px). Pixval N maps directly to
                      (adybug/src/main.s):00280         ;   palette idx N — chosen because every idx 0/1/2/3 appears in the tile,
                      (adybug/src/main.s):00281         ;   so a wrong palette entry is immediately obvious.
                      (adybug/src/main.s):00282         ;
                      (adybug/src/main.s):00283         ;   Source pixval rows (from chars.json[432]):
                      (adybug/src/main.s):00284         ;     3,3,3,3,3,1,3,3
                      (adybug/src/main.s):00285         ;     3,3,3,1,1,1,3,3
                      (adybug/src/main.s):00286         ;     3,3,1,1,1,1,1,0
                      (adybug/src/main.s):00287         ;     3,3,1,1,1,1,1,2
                      (adybug/src/main.s):00288         ;     3,3,1,1,1,1,1,2
